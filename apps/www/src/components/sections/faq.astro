---
import Section from "../layout/section.astro";
import Card from "../ui/Card.astro";

type FaqEntry = {
  question: string;
  answer: string;
};

const items: Array<FaqEntry> = [
  {
    question: "Who is this product built for?",
    answer:
      "This platform is built for developers, indie hackers, and small teams who run Docker in production or staging and want a clean, focused way to monitor and manage their containers without unnecessary complexity.",
  },
  {
    question: "How long does it take to get started?",
    answer:
      "Getting started takes only a few minutes. Once your access is approved, you install the lightweight agent on your server and immediately start seeing your containers in the dashboard. No complex setup or infrastructure changes required.",
  },
  {
    question: "Will this replace my existing Docker workflow?",
    answer:
      "No. It is designed to complement your existing workflow, not replace it. You can continue using Docker CLI, Compose, or any other tools you rely on. The platform provides visibility and control in a simpler, more accessible interface.",
  },
  {
    question: "Can I use it for production environments?",
    answer:
      "Yes. The platform is designed to work with real production workloads, giving you real-time visibility into container status and activity while keeping your existing deployment processes unchanged.",
  },
  {
    question: "Does it work with remote servers?",
    answer:
      "Yes. The agent runs directly on your server and securely connects to the managed backend, allowing you to monitor remote environments from a single dashboard.",
  },
  {
    question: "What can I actually see and manage from the dashboard?",
    answer:
      "From the dashboard, you can see the status of your containers, whether they are running or stopped, and monitor updates in real time. The goal is to provide a clear operational overview without overwhelming you with unnecessary details.",
  },
];
---

<Section>
  <div class="col-span-12 mb-4 text-left md:text-center">
    <h2 class="mx-0 max-w-2xl text-balance md:mx-auto">
      Frequently Asked Questions
    </h2>
  </div>

  <ul class="col-span-12 m-0 flex list-none flex-col gap-3 p-0 md:col-span-10 md:col-start-2 lg:col-span-8 lg:col-start-3">
    {items.map((item) => (
    <Card as="li" class="rounded-lg!">
      <div>
        <h3>{item.question}</h3>
        <p class="mt-2 text-balance text-sm text-neutral-500">{item.answer}</p>
      </div>
    </Card>
    ))}
  </ul>
</Section>
