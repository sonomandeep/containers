---
import {
  GitBranchIcon,
  LockKeyholeIcon,
  NetworkIcon,
  ServerIcon,
} from "@lucide/astro";
import Section from "../layout/section.astro";
---

<Section>
  <div class="col-span-6 flex flex-col gap-3 text-left text-neutral-500 lg:col-span-3">
    <GitBranchIcon class="size-4"/>

    <div class="flex flex-col gap-1">
      <h3>100% open source</h3>
      <p class="text-balance text-sm">Inspect the code. Contribute. Fork if needed.</p>
    </div>
  </div>

  <div class="col-span-6 flex flex-col gap-3 text-left text-neutral-500 lg:col-span-3">
    <ServerIcon class="size-4"/>

    <div class="flex flex-col gap-1">
      <h3>Deploy anywhere</h3>
      <p class="text-balance text-sm">
        Docker Compose, single server, or your existing stack.
      </p>
    </div>
  </div>

  <div class="col-span-6 flex flex-col gap-3 text-left text-neutral-500 lg:col-span-3">
    <LockKeyholeIcon class="size-4"/>

    <div class="flex flex-col gap-1">
      <h3>No vendor lock</h3>
      <p class="text-balance text-sm">No proprietary runtime. Your stack, your rules.</p>
    </div>
  </div>

  <div class="col-span-6 flex flex-col gap-3 text-left text-neutral-500 lg:col-span-3">
    <NetworkIcon class="size-4"/>

    <div class="flex flex-col gap-1">
      <h3>Multi-host ready</h3>
      <p class="text-balance text-sm">
        Deploy agents across your nodes. Monitor in one place.
      </p>
    </div>
  </div>
</Section>
