---
import LogStream from "../features/log-stream.astro";
import MonitorCluster from "../features/monitor-cluster.astro";
import MultiHostSupport from "../features/multi-host-support.astro";
import RemoteTerminal from "../features/remote-terminal.astro";
import Section from "../layout/section.astro";
---

<Section>
  <div class="col-span-12 mb-8 text-left md:text-center">
    <h2 class="mx-0 max-w-2xl text-balance md:mx-auto">
      Everything you need to deploy, run and manage your containerized services
    </h2>
  </div>

  <MonitorCluster class="col-span-12 h-80 md:col-span-6"/>
  <LogStream class="col-span-12 md:col-span-6"/>

  <MultiHostSupport class="col-span-12 h-80 md:col-span-6"/>
  <RemoteTerminal class="col-span-12 h-80 md:col-span-6"/>
</Section>
