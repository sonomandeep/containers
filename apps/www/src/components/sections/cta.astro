---
import Section from "../layout/section.astro";
import Button from "../ui/Button.astro";
---

<Section>
  <div class="col-span-12 flex flex-col gap-6 rounded-xl bg-neutral-50 px-4 py-12 text-center sm:px-6 sm:py-14 md:px-8 md:py-16">
    <h2 class="mx-auto max-w-xl text-balance text-center">
      Stop overpaying managed platforms.
    </h2>

    <div class="flex w-full flex-wrap items-center justify-center gap-3 sm:gap-4 md:flex-nowrap">
      <Button>Join Waitlist</Button>
      <Button href="#demo" variant="secondary">Open Demo</Button>
    </div>
  </div>
</Section>
