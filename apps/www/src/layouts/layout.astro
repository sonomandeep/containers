---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Paper - Ship like a PaaS, stay self-hosted.",
  description = "Deploy containers on your VPS in minutes, monitor them live and execute commands.",
} = Astro.props as Props;
---

<!DOCTYPE html>
<!-- biome-ignore lint/nursery/noSyncScripts: visitors -->
<script
  src="https://cdn.visitors.now/v.js"
  data-token="fc66e70f-3c00-4b3f-a643-df68d8c9b447"
></script>

<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <link href="/light.svg" media="(prefers-color-scheme: light)" rel="icon">
    <link href="/dark.svg" media="(prefers-color-scheme: dark)" rel="icon">
    <meta content={description} name="description">
    <meta content={Astro.generator} name="generator">
    <title>{title}</title>
  </head>

  <body>
    <main>
      <slot/>
    </main>
  </body>
</html>
